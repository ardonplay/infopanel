// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Pages {
  id Int @id @default(autoincrement()) @unique
  title String
  type String
  related_id Int
}

model Users {
  id Int @id @default(autoincrement()) @unique
  login String @unique
  password String
}

model PlainText {
  id Int @id @default(autoincrement()) @unique
  content String
}

model InformationSlider {
  id Int @id @default(autoincrement()) @unique
}